	quest.1A4BF150FAFDF462.quest_desc: [
		"Unlike standard magical worlds, you won't find Archwood Trees growing naturally in the Overworld. To harness the power of magical wood, you’ll have to synthesize it yourself through alchemical infusion."
		""
		"&lThe Process&r: You must imbue standard Planks with Lumisene to begin the transformation."
	]
	quest.1A4BF150FAFDF462.quest_subtitle: "From Wood To Wizardry"
	quest.1CEA883424AFF401.quest_subtitle: "Charging"
	quest.1D115890A4C2330B.quest_desc: [
		"Mimic Dust is a chaotic, transformative substance from the Relics mod. It allows you to harness the fickle nature of Mimics to gamble for better loot and recycle your unwanted treasures."
		""
		"The Sacrifice: Place any unwanted Relic or Artifact into a Crushing Wheel to break it down into raw Mimic Dust."
		""
		""
		"&lFill the Chest&r: Place the Relics you wish to \"reroll\" inside a chest."
		""
		"&lApply the Dust&r: Shift + Right-click the chest with your Mimic Dust."
		""
		"&lThe Awakening&r: The chest will instantly transform into a Mimic!"
		""
		"The Reroll: Once the Mimic is defeated, the Relics inside will drop rerolled."
	]
	quest.1D115890A4C2330B.quest_subtitle: "RNG: The Item."
	quest.1D115890A4C2330B.title: "RE-ROLL"

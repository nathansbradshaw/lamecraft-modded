	quest.32C9F58F2C9D9D01.quest_desc: ["The Technomancer's Gear from Ars Technica is the ultimate synthesis of mechanical utility and arcane protection. Designed specifically for the engineer who isn't afraid to dabble in the arts of Source, this armor set bridges the gap between a simple hazmat suit and a high-tier wizard's robe."]
	quest.32C9F58F2C9D9D01.quest_subtitle: "Fashion Meets Function"
	quest.3392053D3B462CFC.quest_subtitle: "Place Mid Air"
	quest.35147A998DBCDB3A.quest_desc: [
		"In this modpack, the Create Crafts \\& Additions mod bridges the gap between kinetic rotation and electrical power (FE/RF). This allows your Water Wheels and Windmills to power machines from other mods, or vice-versa!"
		""
		"You can toggle a Connector between Input and Output modes by right-clicking it with a Create Wrench."
	]
	quest.35147A998DBCDB3A.quest_subtitle: "You Can Charge Things"

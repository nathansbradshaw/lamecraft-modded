	quest.4EEAE34EEC706FC7.quest_desc: [
		"Welcome to a world where gears grind in unison with arcane magic and digital matter. Create Integrated is a curated experience that blends the mechanical complexity of Create with the utility of Just Dire Things, MAGIC of Ars, and the power of Replication."
		""
		"As you progress, you’ll find that the lines between technology and magic have been blurred. Your challenge is not just to automate, but to engineer a factory where every piece fits together perfectly."
	]
	quest.4EEAE34EEC706FC7.quest_subtitle: "Seamless. Integrated. Unified."
	quest.4EEAE34EEC706FC7.title: "Welcome To Create Integrated"

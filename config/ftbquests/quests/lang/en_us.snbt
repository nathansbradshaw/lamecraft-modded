	quest.245FE3963B28BEAC.quest_desc: [
		"The Andesite Machine is the primary chassis for this era. It is crafted from the Andesite Mechanism and serves as the base for almost every component in the Andesite Age."
		""
		"While you can start by crafting these manually, they can be produced much more efficiently using Sequenced Assembly. Setting up a line of Deployers will save you resources and time as you scale up your factory!"
	]
	quest.245FE3963B28BEAC.quest_subtitle: "Industrial Baby Steps"
	quest.284F2EFF88CD7178.quest_desc: ["Ultimine isn't just for destruction! You can also use it to mass-interact with Create blocks and Wrench multiple machines simultaneously."]

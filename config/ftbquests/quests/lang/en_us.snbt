	quest.6A0D1F63AE045AED.quest_desc: [
		"Instead of manually placing Soul Sand and Skulls, this mod uses a Mechanical Spawner block."
		""
		"Rotational Power: The spawner requires Stress Capacity (SU) and speed to operate."
		""
		"Spawn Fluid: You provide the spawner with a specific \"Wither Spawn Fluid\"."
		""
		"Processing Time: The spawner takes a set amount of time to \"construct\" the Wither before it appears in the world."
		""
		"The &bLoot Collector&r is a specialized block designed to harvest drops without needing a complex player-kill setup."
	]
	quest.6A0D1F63AE045AED.quest_subtitle: "Automated Mob Drops"
	quest.6BDFBA67F35DF0F2.quest_subtitle: "Dire Ingot V2"
	quest.6D8BC7914BB4EAAB.quest_desc: ["There are many ways to make BRASS, or even find brass in the world!"]
